generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A verified AWS SES sending identity (e.g. "no-reply@acme.com").
model Sender {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  region    String    @default("us-east-1")
  createdAt DateTime  @default(now())
  versions  Version[]
}

// Top-level group, e.g. "accounts". Maps to the first path segment.
model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  createdAt DateTime   @default(now())
  templates Template[]
}

// An email template, e.g. "password-recovery". Unique within a category.
model Template {
  id         String           @id @default(cuid())
  slug       String
  name       String
  categoryId String
  category   Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  versions   Version[]
  apiKeys    ApiKeyTemplate[]
  createdAt  DateTime         @default(now())

  @@unique([categoryId, slug])
}

enum VersionStatus {
  DRAFT
  PUBLISHED
}

enum ApiKeyScope {
  ALL // may send any template on the platform
  SELECTED // restricted to the templates in ApiKeyTemplate
}

// A credential distributed to an internal service to call the send API.
// The raw key is shown once at creation; only its hash is persisted.
model ApiKey {
  id         String           @id @default(cuid())
  name       String // dashboard label, e.g. "billing-service prod"
  prefix     String           @unique // public lookup handle (es_<prefix>_...)
  hashedKey  String // sha256 of the secret portion; raw key never stored
  hint       String // masked display, e.g. "es_a1b2…f9"
  scope      ApiKeyScope      @default(SELECTED)
  expiresAt  DateTime? // null = permanent
  revokedAt  DateTime? // null = active (soft revoke)
  lastUsedAt DateTime?
  createdBy  String? // admin email that created it
  createdAt  DateTime         @default(now())
  templates  ApiKeyTemplate[]
}

// Join: which templates a SELECTED-scope key may send. Immutable after creation.
model ApiKeyTemplate {
  apiKeyId   String
  templateId String
  apiKey     ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@id([apiKeyId, templateId])
}

enum EmailStatus {
  SENT
  FAILED
}

// Audit log of every send attempt through the public send API.
model EmailLog {
  id          String      @id @default(cuid())
  status      EmailStatus
  to          String[]
  subject     String      @default("")
  category    String // category slug at send time
  template    String // template slug at send time
  version     Int
  senderEmail String?
  messageId   String? // SES message id (or "dry-run")
  dryRun      Boolean     @default(false)
  errorCode   String? // HttpError message / failure reason
  errorDetail String? // longer error text
  versionId   String? // soft link; kept even if the version is later deleted
  apiKeyId    String? // soft link to the ApiKey used (kept if key later deleted)
  apiKeyName  String? // snapshot of the key name at send time
  createdAt   DateTime    @default(now())

  @@index([createdAt])
  @@index([status])
  @@index([category, template])
}

// An immutable-ish version of a template. Every schema change creates a new one.
model Version {
  id         String        @id @default(cuid())
  version    Int // exposed as "v{n}" in the send API
  templateId String
  template   Template      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  subject    String        @default("")
  mjml       String        @default("") // MJML source with Handlebars vars
  jsonSchema Json          @default("{}") // JSON Schema describing render params
  senderId   String?
  sender     Sender?       @relation(fields: [senderId], references: [id], onDelete: SetNull)
  status     VersionStatus @default(DRAFT)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([templateId, version])
}
