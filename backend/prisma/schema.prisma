generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A verified AWS SES sending identity (e.g. "no-reply@acme.com").
model Sender {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  region    String    @default("us-east-1")
  createdAt DateTime  @default(now())
  versions  Version[]
}

// Top-level group, e.g. "accounts". Maps to the first path segment.
model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  createdAt DateTime   @default(now())
  templates Template[]
}

// An email template, e.g. "password-recovery". Unique within a category.
model Template {
  id         String    @id @default(cuid())
  slug       String
  name       String
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  versions   Version[]
  createdAt  DateTime  @default(now())

  @@unique([categoryId, slug])
}

enum VersionStatus {
  DRAFT
  PUBLISHED
}

enum EmailStatus {
  SENT
  FAILED
}

// Audit log of every send attempt through the public send API.
model EmailLog {
  id          String      @id @default(cuid())
  status      EmailStatus
  to          String[]
  subject     String      @default("")
  category    String // category slug at send time
  template    String // template slug at send time
  version     Int
  senderEmail String?
  messageId   String? // SES message id (or "dry-run")
  dryRun      Boolean     @default(false)
  errorCode   String? // HttpError message / failure reason
  errorDetail String? // longer error text
  versionId   String? // soft link; kept even if the version is later deleted
  createdAt   DateTime    @default(now())

  @@index([createdAt])
  @@index([status])
  @@index([category, template])
}

// An immutable-ish version of a template. Every schema change creates a new one.
model Version {
  id         String        @id @default(cuid())
  version    Int // exposed as "v{n}" in the send API
  templateId String
  template   Template      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  subject    String        @default("")
  mjml       String        @default("") // MJML source with Handlebars vars
  jsonSchema Json          @default("{}") // JSON Schema describing render params
  senderId   String?
  sender     Sender?       @relation(fields: [senderId], references: [id], onDelete: SetNull)
  status     VersionStatus @default(DRAFT)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([templateId, version])
}
