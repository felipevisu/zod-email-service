# Database
DATABASE_URL="postgresql://mail:mail@localhost:5432/maildb?schema=public"

# Server
PORT=4000

# AWS SES
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# When true, emails are NOT sent to SES, only logged. Use for local dev.
SES_DRY_RUN="true"

# --- Auth (management UI / API) ---
# Secret used to sign session JWTs. Use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-string"
# Admin login. Generate the hash with: npm run auth:hash -- "your-password"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH=""

# --- Send API (internal services) ---
# Send keys are managed in the dashboard (Settings → API keys) and stored in
# the database; there is no env-based send secret. Create a key in the UI and
# distribute it to your internal services as the X-Api-Key header.
